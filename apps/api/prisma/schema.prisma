datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  club      Club?
  player    Player?
  reports   Report[]
}

model Club {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  name         String
  category     String
  city         String?
  region       String?
  logoUrl      String?
  website      String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  needs        Need[]
  reports      Report[]
  shortlists   Shortlist[]
}

model Player {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  firstName    String
  lastName     String
  birthdate    DateTime?
  nationality  String    @default("Chilena")
  rut          String?
  heightCm     Int?
  weightKg     Int?
  dominantFoot String?
  photoUrl     String?
  bio          String?
  isAvailable  Boolean  @default(true)
  isPublic     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  positions    PlayerPosition[]
  history      PlayerHistory[]
  videos       Video[]
  applications Application[]
  reports      Report[]
  shortlistPlayers ShortlistPlayer[]
}

model Position {
  id      String @id @default(cuid())
  name    String
  code    String @unique
  players PlayerPosition[]
  needs   Need[]
}

model PlayerPosition {
  playerId   String
  positionId String
  isPrimary  Boolean @default(false)
  player     Player   @relation(fields: [playerId], references: [id])
  position   Position @relation(fields: [positionId], references: [id])
  @@id([playerId, positionId])
}

model PlayerHistory {
  id        String   @id @default(cuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id])
  clubName  String
  category  String?
  season    String?
  matches   Int      @default(0)
  goals     Int      @default(0)
  assists   Int      @default(0)
  minutes   Int      @default(0)
  createdAt DateTime @default(now())
}

model Video {
  id        String   @id @default(cuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id])
  title     String?
  url       String
  type      String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Need {
  id           String   @id @default(cuid())
  clubId       String
  club         Club     @relation(fields: [clubId], references: [id])
  positionId   String?
  position     Position? @relation(fields: [positionId], references: [id])
  title        String
  description  String?
  minAge       Int?
  maxAge       Int?
  dominantFoot String?
  status       String   @default("open")
  deadline     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  applications Application[]
}

model Application {
  id        String   @id @default(cuid())
  needId    String
  need      Need     @relation(fields: [needId], references: [id])
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id])
  message   String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([needId, playerId])
}

model Report {
  id               String   @id @default(cuid())
  playerId         String
  player           Player   @relation(fields: [playerId], references: [id])
  scoutUserId      String
  scout            User     @relation(fields: [scoutUserId], references: [id])
  clubId           String
  club             Club     @relation(fields: [clubId], references: [id])
  matchDate        DateTime?
  matchOpponent    String?
  scoreTechnical   Int?
  scoreTactical    Int?
  scorePhysical    Int?
  scoreMental      Int?
  scorePotential   Int?
  notesTechnical   String?
  notesTactical    String?
  notesPhysical    String?
  notesMental      String?
  summary          String?
  recommendation   String?
  isPrivate        Boolean  @default(false)
  createdAt        DateTime @default(now())
}

model Shortlist {
  id        String   @id @default(cuid())
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id])
  name      String
  createdAt DateTime @default(now())
  players   ShortlistPlayer[]
}

model ShortlistPlayer {
  shortlistId String
  playerId    String
  shortlist   Shortlist @relation(fields: [shortlistId], references: [id])
  player      Player    @relation(fields: [playerId], references: [id])
  notes       String?
  addedAt     DateTime  @default(now())
  @@id([shortlistId, playerId])
}
