# ===========================================
# ScoutChile API - Variables de entorno
# ===========================================
# Copia este archivo como .env y completa los valores

# --- Servidor ---
NODE_ENV=development
PORT=3001
API_VERSION=v1

# --- Base de datos (PostgreSQL / Neon) ---
DATABASE_URL=postgresql://usuario:password@host:5432/scout_chile_db

# --- JWT Auth ---
JWT_SECRET=tu_jwt_secret_aqui_cambiar_en_produccion
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=tu_refresh_secret_aqui
JWT_REFRESH_EXPIRES_IN=30d

# --- CORS ---
CORS_ORIGIN=http://localhost:3000

# --- Storage (Fase 2) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=scout-chile-media

# --- Email (Fase 2) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@scoutchile.cl

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
